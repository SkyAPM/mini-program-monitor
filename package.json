{
  "name": "mini-program-monitor",
  "version": "0.4.0",
  "description": "WeChat and Alipay Mini Program monitoring agent for Apache SkyWalking",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "miniprogram": "dist",
  "sideEffects": false,
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "README.md",
    "CHANGES.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@swc/core": "^1.15.26",
    "@types/wechat-miniprogram": "^3.4.0",
    "protobufjs": "^8.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkyAPM/mini-program-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/SkyAPM/mini-program-monitor/issues"
  },
  "homepage": "https://github.com/SkyAPM/mini-program-monitor#readme",
  "keywords": [
    "skywalking",
    "wechat",
    "alipay",
    "miniprogram",
    "monitoring",
    "apm",
    "observability"
  ]
}
